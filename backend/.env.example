# Railway Environment Variables Template
# Copy this to Railway's Environment Variables section

# Node Environment (automatically set by nixpacks)
NODE_ENV=production

# JWT Secret (CHANGE THIS!)
JWT_SECRET=your_super_secure_jwt_secret_here_change_this

# Port (Railway automatically provides this)
PORT=5000

# Database Path (SQLite - for local dev)
# In production, consider migrating to Railway's PostgreSQL
DB_PATH=./data/haydays.db
